# ============================================
# Portfolio — Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env with real credentials
# ============================================

# --------------------------------------------
# Chat API (Gemini) — Required for AI chat widget
# --------------------------------------------
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --------------------------------------------
# GitHub Token — Required for generate-projects/skills scripts
# --------------------------------------------
# Create at: https://github.com/settings/tokens
# Scopes needed: public_repo (read-only)
GITHUB_TOKEN=

# --------------------------------------------
# Google Drive (Service Account) — Required for certificate ingestion
# --------------------------------------------
# Create a Service Account at: https://console.cloud.google.com/iam-admin/serviceaccounts
# Enable Google Drive API, download JSON key, paste entire JSON here (single line)
GOOGLE_SERVICE_ACCOUNT_KEY=

# Google Drive folder ID containing certificate PDFs
# (the long string in the folder URL after /folders/)
GOOGLE_DRIVE_FOLDER_ID=
